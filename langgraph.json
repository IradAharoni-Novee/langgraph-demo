{
  "$schema": "https://langgra.ph/schema.json",
  "python_version": "3.13",
  "dependencies": [
    "."
  ],
  "graphs": {
    "simple": "./agents/simple/graph.py:build_graph",
  },
  "env": ".env",
  "image_distro": "wolfi",
  "pip_installer": "uv",
  "checkpointer": {
    "ttl": {
      "strategy": "delete",
      "sweep_interval_minutes": 10,
      "default_ttl": 43200
    }
  },
  "store": {
    "index": {
      "embed": "openai:text-embedding-3-small",
      "dims": 1536,
      "fields": [
        "$"
      ]
    },
    "ttl": {
      "refresh_on_read": true,
      "sweep_interval_minutes": 60,
      "default_ttl": 10080
    }
  },
  "http": {
    "cors": {
      "allow_origins": [
        "*"
      ]
    }
  }
}